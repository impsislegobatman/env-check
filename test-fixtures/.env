# Database
DATABASE_URL=postgres://prod-host:5432/proddb
DATABASE_POOL_SIZE=25

# Auth
JWT_SECRET=super-secret-production-key
# SESSION_TTL is missing on purpose

# Third-party
STRIPE_SECRET_KEY=sk_live_real_key
SENDGRID_API_KEY=SG.xxxxx

# Feature flags
export ENABLE_BETA=true

# Multiline test
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
real-key-content
-----END RSA PRIVATE KEY-----"

# Quoted
APP_NAME='Production App'
GREETING="Hello, Production!"

# Extra variables not in example
SENTRY_DSN=https://sentry.io/xxx
DEBUG=false
