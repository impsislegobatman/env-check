# Database
DATABASE_URL=postgres://localhost:5432/mydb
DATABASE_POOL_SIZE=10

# Auth
JWT_SECRET=change-me
SESSION_TTL=3600

# Third-party
STRIPE_SECRET_KEY=sk_test_xxx
SENDGRID_API_KEY=

# Feature flags
export ENABLE_BETA=false

# Multiline test
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
example
-----END RSA PRIVATE KEY-----"

# Quoted values
APP_NAME='My App'
GREETING="Hello, World!"
