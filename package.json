{
  "name": "env-check",
  "version": "1.0.0",
  "description": "Validate that your .env file has all variables defined in .env.example",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "env-check": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "env",
    "dotenv",
    "environment",
    "variables",
    "validation",
    "ci",
    "check",
    "lint"
  ],
  "author": "impsislegobatman",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
